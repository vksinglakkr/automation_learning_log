    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const aiText = $input.item.json.choices[0].message.content;\n\nconst deptMatch = aiText.match(/DEPARTMENT:\\s*(\\w+)/i);\nconst dept = deptMatch ? deptMatch[1].toUpperCase().trim() : 'OTHERS';\n\nconst routingMap = {\n  'CRED':    'REPLACE_WITH_CRED_OFFICER_EMAIL@example.gov.in',\n  'PENSION': 'REPLACE_WITH_PENSION_OFFICER_EMAIL@example.gov.in',\n  'AADHAAR': 'REPLACE_WITH_AADHAAR_OFFICER_EMAIL@example.gov.in',\n  'RATION':  'REPLACE_WITH_RATION_OFFICER_EMAIL@example.gov.in',\n  'REVENUE': 'REPLACE_WITH_REVENUE_OFFICER_EMAIL@example.gov.in',\n  'PPP':     'REPLACE_WITH_PPP_OFFICER_EMAIL@example.gov.in',\n  'OTHERS':  'REPLACE_WITH_DEFAULT_OFFICER_EMAIL@example.gov.in'\n};\n\nconst officerLabels = {\n  'CRED':    'ADC (CRED)',\n  'PENSION': 'DSWO (Pension)',\n  'AADHAAR': 'ADC (Aadhaar)',\n  'RATION':  'DFSC (Ration)',\n  'REVENUE': 'DRO (Revenue)',\n  'PPP':     'ADC (PPP)',\n  'OTHERS':  'DC Office'\n};\n\nconst officerEmail = routingMap[dept] || routingMap['OTHERS'];\nconst officerLabel = officerLabels[dept] || officerLabels['OTHERS'];\n\nreturn {\n  json: {\n    ...$input.item.json,\n    routedTo: officerEmail,\n    officerLabel: officerLabel,\n    department: dept,\n    aiAnalysis: aiText\n  }\n};"
      },
