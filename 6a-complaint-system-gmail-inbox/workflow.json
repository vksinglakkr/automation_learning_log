        "nodeCredentialType": "groqApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an assistant to District Administration Kurukshetra. First check if this is a genuine complaint, grievance, application, or request from a citizen. If it is NOT genuine (e.g. newsletter, promotional, automated, OTP, notification, receipt, invoice), respond with ONLY: NOT_A_COMPLAINT\\n\\nIf it IS genuine, respond ONLY in this exact format:\\n\\nDEPARTMENT: [CRED/PENSION/AADHAAR/RATION/REVENUE/PPP/OTHERS]\\nCATEGORY: [brief category]\\nPRIORITY: [High/Medium/Low]\\nLOCATION: [location if mentioned, else Not specified]\\nSUMMARY: [2-line summary]\\nACTION: [recommended action in one line]\\n\\nDepartment rules:\\n- CRED: credit, loan, bank, finance, money, recovery\\n- PENSION: pension, retirement, old age, senior citizen\\n- AADHAAR: aadhaar, aadhar, uid, biometric, enrollment\\n- RATION: ration, PDS, food supply, ration card, wheat, grain\\n- REVENUE: land, property, fard, mutation, jamabandi, intkal, registry, khasra\\n- PPP: parivar pehchan patra, PPP, family id, pehchan\\n- OTHERS: water, electricity, roads, sanitation, or anything else\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"From: {{ $('New Complaint Email').item.json.From }}\\nSubject: {{ $('New Complaint Email').item.json.Subject }}\\nEmail Body:\\n{{ $('New Complaint Email').item.json.text !== undefined && $('New Complaint Email').item.json.text !== '' ? $('New Complaint Email').item.json.text : $('New Complaint Email').item.json.snippet }}\"\n    }\n  ]\n}",
        "options": {}
      },
