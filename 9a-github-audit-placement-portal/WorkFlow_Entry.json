{
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "submit-placement-app",
        "options": {
          "allowedOrigins": "*"
        }
      },
      "id": "wa-webhook",
      "name": "Webhook Ingestion",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        260,
        240
      ]
    },
    {
      "parameters": {
        "operation": "append",
