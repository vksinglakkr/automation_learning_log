            "College_Name": "={{ $json.body.student_college }}",
            "GitHub_Username": "={{ $json.body.github_username }}",
            "Registration_Date": "={{ $now.format('yyyy-MM-dd') }}",
            "Audit_Status": "Pending"
          },
          "matchingColumns": []
        },
        "options": {}
      },
      "id": "wa-sheet",
      "name": "Append to Database",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.1,
      "position": [
        480,
        240
      ]
    }
  ],
  "connections": {
    "Webhook Ingestion": {
      "main": [
        [
          {
            "node": "Append to Database",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
