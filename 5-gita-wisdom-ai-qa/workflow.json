    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst errors = [];\nconst student_name = (body.student_name || '').toString().trim();\nconst contact_email = (body.contact_email || '').toString().trim();\nconst mobile_number = (body.mobile_number || '').toString().trim();\nconst college = (body.college || '').toString().trim();\nconst raw_skills = (body.raw_skills || '').toString().trim();\nconst hackathon_idea = (body.hackathon_idea || '').toString().trim();\n\nif (student_name.length < 2) errors.push('Invalid or missing student_name');\nif (!/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(contact_email)) errors.push('Invalid contact_email');\nif (!/^[6-9]\\d{9}$/.test(mobile_number)) errors.push('Invalid mobile_number (expect 10 digits, starting 6-9)');\nif (college.length < 2) errors.push('Invalid or missing college');\nif (raw_skills.length < 2) errors.push('raw_skills is required');\nif (hackathon_idea.length < 10) errors.push('hackathon_idea is too short');\n\nconst now = new Date();\nconst registration_id = 'IGM-' + now.getTime();\n\nreturn [{\n  json: {\n    valid: errors.length === 0,\n    errors,\n    registration_id,\n    student_name,\n    contact_email,\n    mobile_number,\n    college,\n    raw_skills,\n    hackathon_idea,\n    submitted_at: body.submitted_at || now.toISOString()\n  }\n}];"
      },
      "id": "22224e5e-92ca-47ce-9e11-cf8b91873c28",
