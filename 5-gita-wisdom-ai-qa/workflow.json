    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"temperature\": 0.3,\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an assistant for the International Gita Mahotsav student hackathon at NIC Kurukshetra. Given a student's raw skills text and hackathon idea, return STRICT JSON only with keys: idea_summary (one sentence, under 20 words, in English), idea_category (one of: AI/ML, Web, Mobile, IoT, Data & Analytics, Civic Tech, Other), skill_tags (comma-separated cleaned list, max 8 skills, title case), idea_clarity_score (integer 1-5, 5 = very clear and feasible). Return JSON only, no markdown, no prose, no extra keys.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": (\"Skills: \" + $json.raw_skills + \"\\nIdea: \" + $json.hackathon_idea)\n    }\n  ]\n} }}",
        "options": {
          "timeout": 20000
        }
      },
      "id": "9d93b076-df45-424b-8357-c6dac335c3fd",
      "name": "Groq - Enrich Idea",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const groqResponse = $input.first().json;\nconst reg = $('Validate & Normalize').first().json;\n\nlet ai = {\n  idea_summary: '',\n  idea_category: '',\n  skill_tags: '',\n  idea_clarity_score: ''\n};\n\ntry {\n  const content = groqResponse.choices[0].message.content;\n  const parsed = JSON.parse(content);\n  ai = { ...ai, ...parsed };\n} catch (e) {\n  ai.idea_summary = 'AI enrichment unavailable';\n  ai.idea_category = 'Other';\n}\n\nreturn [{\n  json: {\n    registration_id: reg.registration_id,\n    submitted_at: reg.submitted_at,\n    student_name: reg.student_name,\n    contact_email: reg.contact_email,\n    mobile_number: reg.mobile_number,\n    college: reg.college,\n    raw_skills: reg.raw_skills,\n    ai_skill_tags: ai.skill_tags,\n    hackathon_idea: reg.hackathon_idea,\n    ai_idea_summary: ai.idea_summary,\n    ai_idea_category: ai.idea_category,\n    ai_clarity_score: ai.idea_clarity_score\n  }\n}];"
      },
