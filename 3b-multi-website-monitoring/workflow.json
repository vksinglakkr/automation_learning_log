    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "l3-sites",
              "name": "sites",
              "value": "={{ [\n  { \"name\": \"NIC Kurukshetra\", \"url\": \"https://kurukshetra.nic.in\" },\n  { \"name\": \"Haryana Gov\",     \"url\": \"https://haryana.gov.in\" },\n  { \"name\": \"NIC Main\",        \"url\": \"https://nic.in\" }\n] }}",
              "type": "array"
            }
          ]
        },
        "options": {}
      },
      "id": "b423f40a-2c23-4691-9242-4bee471aa69f",
      "name": "Set Sites List",
