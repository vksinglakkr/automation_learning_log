        "jsCode": "const input = $input.first().json;\nconst aiText = input.choices && input.choices[0] && input.choices[0].message\n  ? input.choices[0].message.content\n  : 'Site recovered.';\n\nconst siteData = $('Compare With Previous').first().json;\n\nreturn [{\n  json: {\n    ...siteData,\n    ai_summary: aiText\n  }\n}];"
      },
