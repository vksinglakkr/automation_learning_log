      "id": "591bc867-9885-4063-aba0-ce9514180286",
      "name": "Check Website",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-2224, 144],
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={{ {\n  \"site_name\": \"kurukshetra.gov.in\",\n  \"checked_at\": $now.toISO(),\n  \"status_code\": $json.statusCode || 0,\n  \"is_up\": ($json.statusCode >= 200 && $json.statusCode < 400) ? true : false,\n  \"error_message\": $json.error ? $json.error.toString() : \"\",\n  \"response_time_ms\": $json.headers && $json.headers['x-response-time'] ? $json.headers['x-response-time'] : \"\"\n} }}",
        "options": {}
      },
      "id": "069a8814-f729-43e6-9010-7a4a9f4d5ef1",
      "name": "Build Log Record",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-2000, 144]
    },
    {
      "parameters": {
        "documentId": { "__rl": true, "mode": "list", "value": "REPLACE_WITH_GOOGLE_SHEET_ID" },
        "sheetName": { "__rl": true, "mode": "name", "value": "SiteLog" },
        "options": { "returnFirstMatch": false }
      },
      "id": "0c19c1e3-8cd4-4934-90cf-616293de1fd8",
      "name": "Read Last Status",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [-1776, 144],
      "credentials": {
        "googleSheetsOAuth2Api": { "id": "zqCFkP1mXpyrkeQ2", "name": "Google Sheets account" }
      }
    },
    {
      "parameters": {
        "jsCode": "// Get all previous rows, find the last one, compare with current check\nconst previousRows = $input.all();\nconst current = $('Build Log Record').first().json;\n\nlet lastStatus = null;\nif (previousRows.length > 0) {\n  const lastRow = previousRows[previousRows.length - 1].json;\n  lastStatus = lastRow.is_up === true || lastRow.is_up === 'true' || lastRow.is_up === 'TRUE';\n}\n\nconst justRecovered = (lastStatus === false && current.is_up === true);\nconst justWentDown = (lastStatus !== false && current.is_up === false);\n\nreturn [{\n  json: {\n    ...current,\n    previous_status_up: lastStatus,\n    just_recovered: justRecovered,\n    just_went_down: justWentDown\n  }\n}];"
      },
      "id": "826fc910-046f-4cf7-adb2-8b4cf13816c0",
      "name": "Compare With Previous",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1552, 144]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": { "__rl": true, "mode": "list", "value": "REPLACE_WITH_GOOGLE_SHEET_ID" },
        "sheetName": { "__rl": true, "mode": "name", "value": "SiteLog" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "site_name": "={{ $json.site_name }}",
            "checked_at": "={{ $json.checked_at }}",
            "status_code": "={{ $json.status_code }}",
            "is_up": "={{ $json.is_up }}",
            "error_message": "={{ $json.error_message }}"
          }
        },
        "options": {}
      },
      "id": "b667ebcb-3e17-4821-b3c1-d937e4617d1b",
      "name": "Log Check to Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [-1344, 144],
      "credentials": {
        "googleSheetsOAuth2Api": { "id": "zqCFkP1mXpyrkeQ2", "name": "Google Sheets account" }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 2 },
          "conditions": [
            {
              "id": "cond-down-1",
              "leftValue": "={{ $json.just_went_down }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "0def57b8-02ef-4fbb-9b1c-5ceb674b2975",
      "name": "Site Just Went Down?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [-1120, 48]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 2 },
          "conditions": [
            {
              "id": "cond-recover-1",
              "leftValue": "={{ $json.just_recovered }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "c906b1e8-45c2-4df0-8dea-4ec56426657c",
      "name": "Site Just Recovered?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [-1120, 272]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "groqApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an IT alert assistant. Write a short, clear bilingual (English then Hindi) outage alert. Keep it under 80 words total.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Website: \" + $json.site_name + \"\\nChecked at: \" + $json.checked_at + \"\\nHTTP status code: \" + $json.status_code + \"\\nError: \" + $json.error_message + \"\\n\\nWrite a brief alert message explaining the site is down and likely cause.\"\n    }\n  ],\n  \"temperature\": 0.3\n} }}",
        "options": {}
      },
      "id": "ab34e8a0-6d9e-44ef-8bf8-ce8cd6cc1d31",
      "name": "Groq - Generate Down Alert",
