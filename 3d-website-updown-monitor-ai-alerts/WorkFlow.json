    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "groqApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an IT alert assistant. Write a short, clear bilingual (English then Hindi) recovery notice. Keep it under 60 words total.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Website: \" + $json.site_name + \"\\nRecovered at: \" + $json.checked_at + \"\\nCurrent status code: \" + $json.status_code + \"\\n\\nWrite a brief message confirming the site is back up.\"\n    }\n  ],\n  \"temperature\": 0.3\n} }}",
        "options": {}
      },
      "id": "22bbb124-1d74-42df-b1c4-2b80a81144b5",
      "name": "Groq - Generate Recovery Notice",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-896, 272],
      "credentials": {
        "groqApi": { "id": "SVypylwZhqG2a8gE", "name": "Groq account" }
      }
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst aiText = input.choices && input.choices[0] && input.choices[0].message\n  ? input.choices[0].message.content\n  : 'AI summary unavailable. Please check the site manually.';\n\nconst siteData = $('Compare With Previous').first().json;\n\nreturn [{\n  json: {\n    ...siteData,\n    ai_summary: aiText\n  }\n}];"
      },
      "id": "ae968512-62d3-4c16-9eba-572319f9fc1d",
