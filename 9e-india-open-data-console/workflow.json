    {
      "parameters": {
        "jsCode": "// Case 5 — build the filtered query string in code.\n// Demonstrates: sanitizing user input, encoding it safely,\n// and assembling the filter object before the HTTP node ever runs.\n\nconst rawState = ($json.state || '').trim();\nconst safeState = rawState\n  .replace(/[^a-zA-Z\\s]/g, '')      // strip anything that isn't a letter or space\n  .split(' ')\n  .map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())\n  .join(' ');\n\nconst resourceId = 'YOUR_RESOURCE_ID';\nconst limit = 10;\n\nconst queryString =\n  `format=json&limit=${limit}&filters[state]=${encodeURIComponent(safeState)}`;\n\nreturn [{\n  json: {\n    ...$json,\n    resourceId,\n    safeState,\n    queryString,\n    fullUrlPath: `https://api.data.gov.in/resource/${resourceId}?${queryString}`\n  }\n}];"
      },
      "id": "code-buildquery-01",
      "name": "Build Query (Code)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-500, 560]
